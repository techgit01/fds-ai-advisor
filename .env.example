# FDS AI 상담사 환경 변수
# 복사 후 .env로 이름 변경: cp .env.example .env

# 필수: NVIDIA NIM API 키
# 발급: https://build.nvidia.com → API Keys → Generate (무료)
NVIDIA_API_KEY=nvapi-your-key-here

# STT
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu

# LLM
NIM_MODEL=openai/gpt-oss-120b-instruct

# TTS
SUPERTONIC_LANGUAGE=ko

# FDS
BANK_NAME=카드사
FRAUD_RISK_THRESHOLD_HIGH=0.6
FRAUD_RISK_THRESHOLD_MEDIUM=0.35

# 기타
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# Asterisk AMI (FreePBX 연동)
ASTERISK_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=fds
ASTERISK_AMI_SECRET=fdsmanager123

# AGI TTS 목소리 (F1~F5 여성 / M1~M5 남성)
TTS_VOICE=F1
