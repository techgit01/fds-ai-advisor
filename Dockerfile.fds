FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    git \
    curl \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 의존성 먼저 (레이어 캐시 활용)
COPY src/requirements_supertonic.txt .
RUN pip install --no-cache-dir -r requirements_supertonic.txt

# 소스 코드
COPY src/app.py .
COPY src/fds_detector.py .
COPY src/fds_detailed_final.py .
COPY src/fraud_suspicion_prompt_detailed.py .
COPY src/fds_fraud_advisor_prompt.py .
COPY src/fds_agi.py .
COPY src/caller.py .
COPY src/templates/ templates/
COPY src/static/ static/

RUN mkdir -p audio/agi_tmp audio/input audio/output logs cache/whisper cache/huggingface cache/supertonic

EXPOSE 5000

ENV PYTHONUNBUFFERED=1
ENV WHISPER_MODEL=base
ENV WHISPER_DEVICE=cpu
ENV SUPERTONIC_LANGUAGE=ko
ENV NIM_MODEL=openai/gpt-oss-120b-instruct
ENV LOG_LEVEL=INFO
ENV PORT=5000

CMD ["python", "app.py"]
