# 주의: Debian 12(bookworm)에는 asterisk 패키지가 없음(릴리스 직전 제거됨).
# asterisk가 포함된 Debian 11(bullseye) 사용.
FROM debian:bullseye-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    asterisk \
    python3 \
    python3-requests \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /audio/agi_tmp /usr/share/asterisk/agi-bin

EXPOSE 5060/udp 5060/tcp
EXPOSE 10000-20000/udp

CMD ["asterisk", "-f", "-vvv"]
